# Postgres
POSTGRES_DB=postgres
POSTGRES_USER=vista_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin_password_here

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password_here

# Milvus (Optional - only if you want to enable authentication)
# MILVUS_COMMON_AUTHORIZATIONENABLE=true
# MILVUS_COMMON_SUPER_USER_PASSWORD=your_milvus_password
